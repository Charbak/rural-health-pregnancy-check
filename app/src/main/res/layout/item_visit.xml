<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Status Indicator -->
        <View
            android:id="@+id/view_status_indicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:background="@color/visit_upcoming" />

        <!-- Visit Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Visit Type -->
            <TextView
                android:id="@+id/text_visit_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANC1"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Visit Description -->
            <TextView
                android:id="@+id/text_visit_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Confirmation and baseline screening"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <!-- Scheduled Date -->
            <TextView
                android:id="@+id/text_scheduled_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Scheduled: Jan 15, 2024"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <!-- Gestational Week Range -->
            <TextView
                android:id="@+id/text_gestational_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Week 8-16"
                android:textColor="@color/text_hint"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Status Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:background="@color/visit_upcoming"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/text_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPCOMING"
                android:textColor="@color/text_white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
